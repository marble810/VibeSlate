{
  "name": "vibeslate",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "# ── Development ──": "",
    "dev": "bun scripts/dev/start-dev.ts",
    "dev:server": "bun run --cwd server dev",
    "dev:web": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "preview": "bun run build && bun run --cwd server start",
    "# ── Docker Deployment ──": "",
    "docker:up": "bun scripts/docker-up.ts",
    "docker:smoke": "bun scripts/docker-smoke.ts",
    "docker:openai:login": "bun scripts/docker-openai-login.ts",
    "# ── Utilities ──": "",
    "help": "bun scripts/help.ts",
    "check:codex-app-server-schema": "bun scripts/check-codex-app-server-schema.ts",
    "openai:auth:login": "bun scripts/openai-auth-login.ts",
    "openai:auth:doctor": "bun scripts/openai-auth-doctor.ts"
  },
  "dependencies": {
    "@openai/codex": "0.140.0",
    "qrcode": "^1.5.4",
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5"
  }
}
