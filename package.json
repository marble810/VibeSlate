{
  "name": "marble-panel",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun run --cwd server dev",
    "dev:web": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "preview": "bun run build && bun run --cwd server start",
    "tailscale": "bun scripts/tailscale.ts",
    "tailscale:stop": "tailscale serve --https=443 off",
    "lan:https": "bun scripts/lan-https.ts",
    "docker:init": "bun scripts/docker-init.ts",
    "docker:up": "bun scripts/docker-up.ts",
    "docker:smoke": "bun scripts/docker-smoke.ts"
  },
  "dependencies": {
    "systeminformation": "^5.31.7",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5"
  }
}
