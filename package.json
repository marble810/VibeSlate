{
  "name": "vibeslate",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "# ── Development ──": "",
    "dev": "bun scripts/dev/start-dev.ts",
    "dev:server": "bun run --cwd server dev",
    "dev:web": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "preview": "bun run build && bun run --cwd server start",
    "# ── Docker Deployment ──": "",
    "docker:up": "bun scripts/docker-up.ts",
    "docker:smoke": "bun scripts/docker-smoke.ts",
    "# ── Utilities ──": "",
    "help": "bun scripts/help.ts",
    "codex:auth": "bun scripts/extract-codex-openai-credentials.ts"
  },
  "dependencies": {
    "systeminformation": "^5.31.7",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5"
  }
}
