# VibeSlate Docker environment
# Copy this file to docker/.env, then fill the values below.

# Core runtime
HOST=0.0.0.0
PORT=12001
MARBLE_DATA_DIR=/app/data

# Provider credentials
# DeepSeek: browser -> platform.deepseek.com -> DevTools -> Authorization header
DEEPSEEK_PLATFORM_TOKEN=
# OpenAI/Codex: use the OpenAI card in the UI for Docker-owned device-code login.
# Do not copy host ~/.codex/auth.json or refresh tokens into this file.
OPENAI_ENABLED=true
OPENAI_AUTH_MODE=codex_app_server_device_code
OPENAI_CODEX_HOME=/app/data/codex-home
OPENAI_CODEX_CLI_PATH=/app/node_modules/.bin/codex
OPENAI_POLL_INTERVAL_SECONDS=300
OPENAI_SQLITE_PATH=/app/data/state/usage.sqlite
OPENAI_AUTH_STATUS_PATH=/app/data/state/auth-status.json
# OpenCode Go: leave empty if unused
OPENCODE_WORKSPACE_ID=
OPENCODE_AUTH_COOKIE=

# Optional password auth
AUTH_ENABLED=false
AUTH_PASSWORD_HASH=
# If you paste an Argon2id hash here, wrap it in single quotes to preserve `$`.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=604800
AUTH_COOKIE_NAME=marble_session

# Optional LAN HTTPS
# Generate certs on the host and mount them into data/docker/certs/.
TLS_ENABLED=false
TLS_CERT_FILE=/app/data/certs/cert.pem
TLS_KEY_FILE=/app/data/certs/key.pem
TLS_ROOT_CA_FILE=/app/data/certs/rootCA.pem

# Optional UI
UI_CUSTOM_ACCENT="#8b5cf6"
