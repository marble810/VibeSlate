{
  // ═══════════════════════════════════════════════════════
  // VibeSlate — 服务端配置
  // 复制此文件为 config.jsonc 并填入你的认证信息
  // ═══════════════════════════════════════════════════════

  // ── DeepSeek Platform ──
  // 获取方式：浏览器登录 platform.deepseek.com → F12 → Network
  // → 任意 XHR 请求 → Request Headers → Authorization: Bearer xxx
  // 复制 Bearer 后面的值（不含 "Bearer "）
  "deepseek_token": "your-bearer-token-here",

  // ── OpenAI Codex / ChatGPT ──
  // 获取方式：安装 Codex CLI/App → 登录 ChatGPT 账号后，
  // 从 ~/.codex/auth.json → tokens.refresh_token 和 tokens.account_id 复制
  // 或运行宿主机脚本：
  //   macOS / Linux: ./docker/GetCodexAuthInfo.sh
  //   PowerShell:    .\docker\GetCodexAuthInfo.ps1
  "openai_refresh_token": "rt.xxx...",
  "openai_account_id": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",

  // ── OpenCode Go ──
  // 获取方式：浏览器打开 opencode.ai → 进入 Go 工作区 →
  // URL 中的 wrk_xxx 就是 workspace_id
  // DevTools → Application → Cookies → 复制 auth 的值
  "opencode_workspace_id": "wrk_xxx...",
  "opencode_auth_cookie": "auth=xxx...",

  // ── 查询间隔（秒）──
  "query_interval_seconds": 60,

  // ── UI Theme ──
  // Custom Accent 只允许配置 accent，不改变背景/文字/surface。
  // 前端 Theme menu 只开放选择项；颜色值从这里读取。
  "ui": {
    "custom_accent": "#f59e0b"
  },

  // ── 可选：密码保护（默认关闭）──
  // 生成 password_hash:
  //   bun -e 'console.log(await Bun.password.hash("change-me"))'
  "auth": {
    "enabled": false,
    "password_hash": "$argon2id$v=19$m=65536,t=2,p=1$...",
    "session_ttl_seconds": 604800,
    "cookie_name": "marble_session",
    "cookie_secure": true
  },

  // ── 可选：TLS / LAN HTTPS（默认关闭）──
  // 开启后，cert/key/root CA 路径都必须可读。
  "tls": {
    "enabled": false,
    "cert_file": "/absolute/path/to/cert.pem",
    "key_file": "/absolute/path/to/key.pem",
    "root_ca_file": "/absolute/path/to/rootCA.pem"
  }
}
